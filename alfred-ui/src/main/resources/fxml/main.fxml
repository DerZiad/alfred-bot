<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.StackPane?>

<!--
    Cinematic Alfred shell. The actual HUD (orb, rings, particles,
    transcript) is composed in Java by HudView and mounted into this
    StackPane by MainController#initialize. Keeping the FXML minimal
    keeps reactive bindings out of FXML expressions.
-->
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:id="rootContainer"
           fx:controller="org.tech.alfred.ui.view.MainController"
           styleClass="alfred-shell"/>
