<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.tech.alfred.ui.view.MainController"
            styleClass="alfred-root">
    <center>
        <TextArea fx:id="transcript" editable="false" wrapText="true" styleClass="alfred-transcript">
            <BorderPane.margin>
                <Insets top="12" right="12" bottom="6" left="12"/>
            </BorderPane.margin>
        </TextArea>
    </center>
    <bottom>
        <HBox spacing="8" styleClass="alfred-input-row">
            <padding>
                <Insets top="6" right="12" bottom="12" left="12"/>
            </padding>
            <TextField fx:id="input" promptText="Ask Alfred..." HBox.hgrow="ALWAYS"/>
            <Button fx:id="sendButton" text="Send" defaultButton="true"/>
        </HBox>
    </bottom>
</BorderPane>
